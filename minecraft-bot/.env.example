# Minecraft Bot Configuration Example
# Copy this file to .env and fill in your values

# Minecraft Server Connection
MC_HOST=localhost
MC_PORT=25565

# Bot Account
# For online mode, use your Microsoft account
MC_USERNAME=YourBotName
MC_PASSWORD=your_microsoft_password
MC_AUTH=microsoft

# For offline mode (no auth), use:
# MC_AUTH=offline

# AI Coordinator WebSocket URL
COORDINATOR_URL=ws://localhost:8080/bot

# Bot Behavior
START_FROM_SCRATCH=true
AUTO_GATHER_RESOURCES=true

# Building Settings
BUILD_SPEED=normal
MAX_REACH_DISTANCE=4.5

# AI/ML Settings
USE_RL=false
RL_MODEL_PATH=./models/best_model.zip
LEARNING_RATE=0.001

# Logging
LOG_LEVEL=info
